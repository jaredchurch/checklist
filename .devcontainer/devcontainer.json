{
	"image": "mcr.microsoft.com/devcontainers/javascript-node",
	"features": {
		"ghcr.io/devcontainers-extra/features/npm-package:1": {
			"package": "opencode"
		},
		"./features/npm-global": {
			"packages": "gh"
		}
	},
	"postCreateCommand": "sudo sed -i '/en_NZ.UTF-8/s/^# //' /etc/locale.gen && sudo locale-gen en_NZ.UTF-8",
	"containerEnv": {
		"LANG": "en_NZ.UTF-8",
		"LC_ALL": "en_NZ.UTF-8"
	},
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash"
			}
		}
	}
}